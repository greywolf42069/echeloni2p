# Solana wallet-adapter pulls in transitive react-native deps that peer
# on @types/react ^19. We pin @types/react to ^18 to match React 18.
# legacy-peer-deps lets npm install both without aborting.
legacy-peer-deps=true

# Skip native postinstall scripts (the `usb` ledger module breaks
# without node-gyp-build present, and we don't expose Ledger anyway).
ignore-scripts=true
