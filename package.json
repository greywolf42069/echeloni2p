{
  "name": "echelon-meshnet",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "pytest": "pytest scripts/tests/",
    "pwa:audit": "node scripts/pwa_audit.mjs",
    "audit": "npm audit --omit=dev --audit-level=high; echo '[python] runtime daemon is pure stdlib (no pip deps); dev-only: Pillow for scripts/gen_icons.py, pytest'",
    "ci": "./node_modules/.bin/tsc --noEmit && ./node_modules/.bin/vite build && node scripts/pwa_audit.mjs && ./node_modules/.bin/vitest run && python3 -m pytest scripts/tests/"
  },
  "dependencies": {
    "@google/genai": "1.29.0",
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "@solana-mobile/wallet-adapter-mobile": "^2.2.8",
    "@solana/spl-token": "0.4.8",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "0.15.35",
    "@solana/wallet-adapter-react-ui": "0.9.35",
    "@solana/wallet-adapter-wallets": "0.19.32",
    "@solana/web3.js": "1.95.0",
    "buffer": "6.0.3",
    "file-saver": "^2.0.5",
    "isomorphic-git": "^1.38.3",
    "jszip": "^3.10.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "9.0.1",
    "react-syntax-highlighter": "15.5.0",
    "recharts": "2.12.7",
    "remark-gfm": "4.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.14.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^2.0.5",
    "autoprefixer": "^10.4.20",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.0",
    "msw": "^2.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
